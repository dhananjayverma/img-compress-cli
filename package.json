{
   "name": "@dhananjay_verma9546/pixora-compress",
   "version": "1.1.0",
   "description": "Pixora — Industry-grade asset optimization toolkit. Compress, convert, audit, generate responsive images, BlurHash, LQIP, dominant colors, sprite sheets, SVG optimization, and more.",
   "type": "module",
   "bin": {
      "pixora": "./dist/cli.js"
   },
   "main": "./dist/index.cjs",
   "module": "./dist/index.js",
   "types": "./dist/index.d.ts",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
         },
         "require": {
            "types": "./dist/index.d.cts",
            "default": "./dist/index.cjs"
         }
      }
   },
   "files": [
      "dist",
      "README.md",
      "LICENSE"
   ],
   "engines": {
      "node": ">=20"
   },
   "scripts": {
      "build": "tsup",
      "dev": "tsx src/cli.ts",
      "test": "vitest run",
      "test:watch": "vitest",
      "lint": "eslint src/ tests/",
      "format": "prettier --write .",
      "format:check": "prettier --check .",
      "typecheck": "tsc --noEmit",
      "prepublishOnly": "npm run build",
      "clean": "rm -rf dist coverage"
   },
   "keywords": [
      "pixora",
      "image",
      "compression",
      "cli",
      "sharp",
      "webp",
      "avif",
      "optimize",
      "resize",
      "convert",
      "png",
      "jpeg",
      "batch",
      "blurhash",
      "lqip",
      "responsive-images",
      "sprite",
      "svgo",
      "audit",
      "benchmark",
      "asset-optimization"
   ],
   "author": "Dhananjay Verma",
   "license": "MIT",
   "repository": {
      "type": "git",
      "url": "https://github.com/dhananjayverma/img-compress-cli.git"
   },
   "bugs": {
      "url": "https://github.com/dhananjayverma/img-compress-cli/issues"
   },
   "dependencies": {
      "blurhash": "^2.0.5",
      "chalk": "^5.6.2",
      "cheerio": "^1.2.0",
      "cli-progress": "^3.12.0",
      "cli-table3": "^0.6.5",
      "commander": "^15.0.0",
      "consola": "^3.4.2",
      "cosmiconfig": "^9.0.2",
      "exifr": "^7.1.3",
      "fast-glob": "^3.3.3",
      "fs-extra": "^11.3.6",
      "inquirer": "^14.0.2",
      "ora": "^9.4.1",
      "sharp": "^0.35.3",
      "ssim.js": "^3.5.0",
      "svgo": "^4.0.1",
      "zod": "^4.4.3"
   },
   "devDependencies": {
      "@types/cli-progress": "^3.11.6",
      "@types/fs-extra": "^11.0.4",
      "@types/inquirer": "^9.0.10",
      "@types/node": "^26.1.0",
      "eslint": "^10.6.0",
      "prettier": "^3.9.4",
      "tsup": "^8.5.1",
      "tsx": "^4.20.3",
      "typescript": "^6.0.3",
      "vitest": "^4.1.9"
   }
}
