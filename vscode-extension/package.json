{
  "name": "vscode-pixora",
  "displayName": "Pixora Developer Asset Optimization",
  "description": "Developer Asset Optimization Platform in your editor. Compress assets, run audits, and analyze layout performance.",
  "version": "1.0.0",
  "publisher": "dhananjayverma",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhananjayverma/img-compress-cli"
  },
  "homepage": "https://github.com/dhananjayverma/img-compress-cli",
  "bugs": {
    "url": "https://github.com/dhananjayverma/img-compress-cli/issues"
  },
  "keywords": [
    "image",
    "compression",
    "optimizer",
    "webp",
    "avif",
    "pixora",
    "sharp"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-pixora.compressFile",
        "title": "Pixora: Compress Image"
      },
      {
        "command": "vscode-pixora.auditWorkspace",
        "title": "Pixora: Audit Workspace for Unoptimized Assets"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "vscode-pixora.compressFile",
          "when": "resourceExtname == .png || resourceExtname == .jpg || resourceExtname == .jpeg || resourceExtname == .webp || resourceExtname == .avif || resourceExtname == .gif || resourceExtname == .svg",
          "group": "modification"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@dhananjay_verma9546/pixora-compress": "file:.."
  },
  "dependencies": {}
}

